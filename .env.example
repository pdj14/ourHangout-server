NODE_ENV=development
PORT=3000

POSTGRES_DB=ourhangout
POSTGRES_USER=ourhangout
POSTGRES_PASSWORD=ourhangout_dev_pw
DATABASE_URL=postgresql://ourhangout:ourhangout_dev_pw@postgres:5432/ourhangout
REDIS_URL=redis://redis:6379

JWT_SECRET=replace-with-a-very-long-random-secret-value-32chars+
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=14

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute

OPENCLAW_MODE=mock
OPENCLAW_BASE_URL=http://127.0.0.1:18888
OPENCLAW_TIMEOUT_MS=3000
OPENCLAW_RETRY_COUNT=2

PAIRING_CODE_TTL_SECONDS=300
LOG_LEVEL=info
